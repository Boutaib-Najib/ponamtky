# Copy to .env and set values. Flask loads this via python-dotenv on startup.

# Required (used by providers in config/configNewsClassifier.json via "ENV:OPENAI_API_KEY")
OPENAI_API_KEY=

# Optional: extra Playwright concurrency (if implemented in web_scraper)
# PLAYWRIGHT_WORKER_THREADS=3

# Required: absolute path to prompt templates directory
PROMPTS_PATH=
# Optional (default: true): when true, Jinja reloads changed prompt templates
# automatically on the next request without restarting the server.
PROMPTS_AUTO_RELOAD=true

# Optional: max upload size for read=3 (multipart upload)
MAX_UPLOAD_MB=20

# Optional: logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# --- API auth (applies to /api/news-classifier/* endpoints) ---
# Enable/disable auth (default: true)
AI_AUTH_ENABLED=true
#
# Path to a newline-delimited text file of allowed keys.
# Lines starting with '#' and blank lines are ignored.
# If not set, requests to /api/news-classifier/* are rejected.
AI_AUTH_KEYS_FILE=
#
# How often to refresh keys from disk (seconds). Default: 300 (5 minutes).
AI_AUTH_REFRESH_SECONDS=300
